{
  "productName": "Whisper Scribe",
  "version": "1.0.0",
  "identifier": "com.whisperscribe.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Whisper Scribe",
        "width": 380,
        "height": 560,
        "minWidth": 300,
        "minHeight": 400,
        "resizable": true,
        "decorations": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "scripts/mlx_transcribe.py",
      "scripts/mlx_screen_analyze.py",
      "scripts/screen_requirements.txt"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "entitlements": "Entitlements.plist",
      "signingIdentity": "Whisper Scribe Dev",
      "infoPlist": "Info.plist"
    }
  }
}
